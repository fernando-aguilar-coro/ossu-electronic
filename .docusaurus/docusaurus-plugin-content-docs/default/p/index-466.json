ar":"tutorialSidebar"},"parte-1-introduccion-y-errores/cap3-errores":{"id":"parte-1-introduccion-y-errores/cap3-errores","title":"Aproximaciones y Errores de Redondeo","description":"Clasificación general de los errores numéricos","sidebar":"tutorialSidebar"},"parte-1-introduccion-y-errores/cap4-taylor":{"id":"parte-1-introduccion-y-errores/cap4-taylor","title":"La Serie de Taylor y Errores de Truncamiento","description":"La Serie de Taylor","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap5-metodos-cerrados/biseccion":{"id":"parte-2-raices-ecuaciones/cap5-metodos-cerrados/biseccion","title":"Método de Bisección","description":"Idea fundamental","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap5-metodos-cerrados/comparativa":{"id":"parte-2-raices-ecuaciones/cap5-metodos-cerrados/comparativa","title":"Comparativa y Criterios de Selección","description":"Resumen de propiedades","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap5-metodos-cerrados/falsa-posicion":{"id":"parte-2-raices-ecuaciones/cap5-metodos-cerrados/falsa-posicion","title":"Método de Falsa Posición (Regula Falsi)","description":"Idea fundamental","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap6-metodos-abiertos/comparativa":{"id":"parte-2-raices-ecuaciones/cap6-metodos-abiertos/comparativa","title":"Comparativa y Criterios de Selección","description":"Los métodos abiertos ofrecen una velocidad de convergencia significativamente superior a la de los métodos cerrados, pero introducen el riesgo de divergencia si la estimación inicial no es adecuada. En este subcapítulo analizamos detalladamente las fortalezas, debilidades y criterios de selección para cada método abierto.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap6-metodos-abiertos/newton-raphson":{"id":"parte-2-raices-ecuaciones/cap6-metodos-abiertos/newton-raphson","title":"Método de Newton-Raphson","description":"El método de Newton-Raphson es uno de los algoritmos de búsqueda de raíces más populares y eficientes. Es un método abierto que utiliza el valor de la función y de su primera derivada para realizar estimaciones cada vez más precisas de la raíz.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap6-metodos-abiertos/punto-fijo":{"id":"parte-2-raices-ecuaciones/cap6-metodos-abiertos/punto-fijo","title":"Método de Punto Fijo","description":"1. Fundamento Matemático","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap6-metodos-abiertos/secante":{"id":"parte-2-raices-ecuaciones/cap6-metodos-abiertos/secante","title":"Método de la Secante","description":"El método de la Secante es un algoritmo de búsqueda de raíces que surge como una alternativa a Newton-Raphson, diseñada para evitar el cálculo analítico de la derivada de la función. Para ello, aproxima la derivada mediante una recta secante que pasa por dos estimaciones iniciales consecutivas.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap7-raices-polinomios/deflacion-horner":{"id":"parte-2-raices-ecuaciones/cap7-raices-polinomios/deflacion-horner","title":"Deflación y División Sintética (Horner)","description":"Cuando encontramos una raíz $r$ de un polinomio $P_n(x)$, podemos reducir su grado para facilitar la búsqueda de las raíces restantes mediante un proceso llamado deflación.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap7-raices-polinomios/localizacion-cauchy":{"id":"parte-2-raices-ecuaciones/cap7-raices-polinomios/localizacion-cauchy","title":"Límites de Cauchy para Raíces","description":"Encontrar estimaciones iniciales adecuadas es fundamental para evitar la divergencia en los métodos polinomiales. Para ello, existen teoremas que nos permiten acotar el dominio del plano complejo donde residen las raíces.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap7-raices-polinomios/metodo-bairstow":{"id":"parte-2-raices-ecuaciones/cap7-raices-polinomios/metodo-bairstow","title":"Método de Bairstow","description":"El método de Bairstow es un algoritmo numérico especializado en encontrar todas las raíces de un polinomio, incluyendo raíces reales y complejas complejas conjugadas.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap7-raices-polinomios/metodo-muller":{"id":"parte-2-raices-ecuaciones/cap7-raices-polinomios/metodo-muller","title":"Método de Müller","description":"El método de Müller es una generalización del método de la secante. Mientras que el método de la secante traza una línea recta (polinomio de primer grado) a través de dos puntos para proyectar la raíz, el método de Müller ajusta una parábola (polinomio de segundo grado) a través de tres puntos.","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap7-raices-polinomios/propiedades":{"id":"parte-2-raices-ecuaciones/cap7-raices-polinomios/propiedades","title":"Propiedades de los Polinomios","description":"Un polinomio de grado $n$ tiene la forma general:","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap8-casos-raices/bungee-jump":{"id":"parte-2-raices-ecuaciones/cap8-casos-raices/bungee-jump","title":"Caso 1: Diseño de un Bungee Jump","description":"1. Planteamiento del Problema","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap8-casos-raices/cable-colgante":{"id":"parte-2-raices-ecuaciones/cap8-casos-raices/cable-colgante","title":"Caso 3: Diseño de un Cable de Puente Colgante","description":"1. Planteamiento del Problema","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap8-casos-raices/circuito-diodo":{"id":"parte-2-raices-ecuaciones/cap8-casos-raices/circuito-diodo","title":"Caso 4: Circuito Eléctrico no Lineal (Diodo)","description":"1. Planteamiento del Problema","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap8-casos-raices/tanque-esferico":{"id":"parte-2-raices-ecuaciones/cap8-casos-raices/tanque-esferico","title":"Caso 2: Carga de un Tanque Esférico","description":"1. Planteamiento del Problema","sidebar":"tutorialSidebar"},"parte-2-raices-ecuaciones/cap8-casos-raices/viga-vibracion":{"id":"parte-2-raices-ecuaciones/cap8-casos-raices/viga-vibracion","title":"Caso 5: Ecuación Característica de una Viga","description":"1. Planteamiento del Problema","sidebar":"tutorialSidebar"},"parte-3-ecuaciones-lineales/cap10-lu":{"id":"parte-3-ecuaciones-lineales/cap10-lu","title":"Descomposición LU e Inversión de Matrices","description":"Motivación","sidebar":"tutorialSidebar"},"parte-3-ecuaciones-lineales/cap11-gauss-seidel":{"id":"parte-3-ecuaciones-lineales/cap11-gauss-seidel","title":"Matrices Especiales y Gauss-Seidel","description":"Matrices especiales","sidebar":"tutorialSidebar"},"parte-3-ecuaciones-lineales/cap12-casos-lineales":{"id":"parte-3-ecuaciones-lineales/cap12-casos-lineales","title":"Estudio de Casos — Ecuaciones Algebraicas Lineales","description":"Caso 1: Análisis de circuitos (Ley de Kirchhoff)","sidebar":"tutorialSidebar"},"parte-3-ecuaciones-lineales/cap9_5-jacobi-gauss-seidel":{"id":"parte-3-ecuaciones-lineales/cap9_5-jacobi-gauss-seidel","title":"Métodos Iterativos — Jacobi y Gauss-Seidel","description":"A diferencia de los métodos directos como la Eliminación de Gauss o la Descomposición LU —que buscan obtener la solución exacta en un número finito de pasos—, los métodos iterativos obtienen aproximaciones sucesivamente más precisas partiendo de una estimación inicial.","sidebar":"tutorialSidebar"},"parte-3-ecuaciones-lineales/cap9-gauss":{"id":"parte-3-ecuaciones-lineales/cap9-gauss","title":"Eliminación de Gauss","description":"Sistemas de ecuaciones lineales","sidebar":"tutorialSidebar"},"parte-4-optimizacion/cap13-optimizacion-1d":{"id":"parte-4-optimizacion/cap13-optimizacion-1d","title":"Optimización Unidimensional No Restringida","description":"Conceptos fundamentales","sidebar":"tutorialSidebar"},"parte-4-optimizacion/cap15-prog-lineal":{"id":"parte-4-optimizacion/cap15-prog-lineal","title":"Programación Lineal (Optimización Restringida)","description":"Forma estándar","sidebar":"tutorialSidebar"},"parte-5-ajuste-curvas/cap17-regresion":{"id":"parte-5-ajuste-curvas/cap17-regresion","title":"Regresión por Mínimos Cuadrados","description":"Objetivo","sidebar":"tutorialSidebar"},"parte-5-ajuste-curvas/cap18-interpolacion":{"id":"parte-5-ajuste-curvas/cap18-interpolacion","title":"Interpolación","description":"Diferencia entre regresión e interpolación","sidebar":"tutorialSidebar"},"parte-5-ajuste-curvas/cap19-fourier":{"id":"parte-5-ajuste-curvas/cap19-fourier","title":"Aproximación de Fourier","description":"Series de Fourier","sidebar":"tutorialSidebar"},"parte-6-integracion-diferenciacion/cap21-newton-cotes":{"id":"parte-6-integracion-diferenciacion/cap21-newton-cotes","title":"Fórmulas de Integración de Newton-Cotes","description":"Idea general","sidebar":"tutorialSidebar"},"parte-6-integracion-diferenciacion/cap22-gauss-romberg":{"id":"parte-6-integracion-diferenciacion/cap22-gauss-romberg","title":"Cuadratura Gaussiana y Método de Romberg","description":"Extrapolación de Richardson","sidebar":"tutorialSidebar"},"parte-6-integracion-diferenciacion/cap23-diferenciacion":{"id":"parte-6-integracion-diferenciacion/cap23-diferenciacion","title":"Diferenciación Numérica","description":"Fórmulas de diferencias finitas","sidebar":"tutorialSidebar"},"parte-7-edos/cap25-runge-kutta":{"id":"parte-7-edos/cap25-runge-kutta","title":"Métodos de Runge-Kutta para EDOs","description":"Problema de valor inicial (PVI)","sidebar":"tutorialSidebar"},"parte-7-edos/cap27-bvp":{"id":"parte-7-edos/cap27-bvp","title":"Valores en la Frontera y Valores Propios","description":"Problemas de Valor en la Frontera (BVP)","sidebar":"tutorialSidebar"},"parte-8-edps/cap30-edp-parabolicas":{"id":"parte-8-edps/cap30-edp-parabolicas","title":"Diferencias Finitas — Ecuaciones Parabólicas","description":"Contenido en desarrollo...","sidebar":"tutorialSidebar"},"parte-8-edps/cap31-fem":{"id":"parte-8-edps/cap31-fem","title":"Método del Elemento Finito","description":"Contenido en desarrollo...","sidebar":"tutorialSidebar"}}}}